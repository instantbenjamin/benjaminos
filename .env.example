# BenjaminOS — local dev env vars
# Copy this file to .env and fill in only what your local task needs.
# All canonical secrets live in Infisical (project pharoah, env dev).
# Use `infisical run --env=dev -- <cmd>` in production / VPS contexts.

# === Anthropic / OpenAI / Gemini ===
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# === Supabase (BenjaminOS project) ===
# SUPABASE_DATABASE_URL=postgresql://...   # Session pooler URL with search_path=gbrain,public,extensions
# SUPABASE_PROJECT_REF=yttxrgbzcvmeystoheeo

# === Linear ===
# LINEAR_API_KEY=lin_...

# === Raindrop / Readwise (legacy ingest scripts) ===
# RAINDROP_TOKEN=...
# READWISE_TOKEN=...

# === Google Workspace (service account; VPS uses ~/.config/gws/eir-agents-sa.json) ===
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json

# === Telegram (Hermes) ===
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_ALLOWED_USERS=...

# === Infisical (for `infisical run` use; CLI manages this) ===
# INFISICAL_PROJECT_ID=67edc8d3-8fb7-437b-8104-1bcac28bb2cf
# INFISICAL_ENV=dev
